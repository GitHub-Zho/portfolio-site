{
  "name": "portfolio-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy prisma migrate dev",
    "db:seed": "env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy prisma db seed",
    "db:studio": "env -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy prisma studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
